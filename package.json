{
  "name": "gestion-app",
  "private": true,
  "workspaces": ["frontend", "api"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w api\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "start:api": "npm run dev -w api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
